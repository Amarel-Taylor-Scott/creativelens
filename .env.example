# CreativeLens Environment Configuration
# Copy to .env and fill in values

# Database
POSTGRES_PASSWORD=creativelens_dev
DATABASE_URL=postgres://creativelens:creativelens_dev@localhost:5432/creativelens

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=4000
NODE_ENV=development

# Frontend
PUBLIC_API_URL=http://localhost:4000
ORIGIN=http://localhost:3000

# File Uploads
MAX_UPLOAD_SIZE_MB=15
UPLOAD_DIR=./uploads

# External Services (optional)
OPENAI_API_KEY=
REPLICATE_API_KEY=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
